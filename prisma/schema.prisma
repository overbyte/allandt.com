// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


model User {
  id        Int  @id @default(autoincrement())
  role      UserRole @default("User")
  name      String
  email     String @unique
  password  String
}

model Profile {
  id     Int @id @default(autoincrement())
  bio    String 
  user   User
  userId Int @unique
}

model Project {
  id           Int @id @default(autoincrement())
  title        String
  type         ProjectType @default("Developer")
  agency       String
  client       String
  description  String
  summary      String
  year         Int
  thumbnail    Asset?
  gallery      Asset[]
  video        String?
  tags         Tag[]
}

model Tag {
  id       Int    @id @default(autoincrement()) 
  name     String @unique
  projects Project[]
}

model UserRole {
  id       Int    @id @default(autoincrement()) 
  name     String @unique
  projects Project[]
}

model ProjectType {
  id       Int    @id @default(autoincrement())
  name     String @unique
  projects Project[]
}

model Asset {
  id       Int    @id @default(autoincrement())
  url      String @unique
  alt      String?
  projects Project[]
}
